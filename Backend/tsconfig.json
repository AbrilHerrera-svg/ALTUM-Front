{
  "compilerOptions": {
    "target": "es2022",                          
    "module": "node16",                        
    "rootDir": "./src",                          
    "moduleResolution": "node16",                  
    "esModuleInterop": true,                     
    "forceConsistentCasingInFileNames": false,            
    "strict": true,                              
    "skipLibCheck": true                         
  },
  "include": ["src/**/*"]
}